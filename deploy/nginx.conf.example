# LokmaGo backend — Nginx reverse proxy + HTTPS
#
# QADAMLAR:
#   1) DNS: api.SIZNING-DOMEN.uz  →  A yozuv  →  server IP
#   2) sudo apt install -y nginx certbot python3-certbot-nginx
#   3) Shu faylni /etc/nginx/sites-available/lakmago ga nusxalang
#      (server_name ni o'z domeningizga o'zgartiring)
#   4) sudo ln -s /etc/nginx/sites-available/lakmago /etc/nginx/sites-enabled/
#      sudo nginx -t && sudo systemctl reload nginx
#   5) sudo certbot --nginx -d api.SIZNING-DOMEN.uz
#      (Certbot HTTPS sertifikatni avtomatik qo'yadi)

server {
    listen 80;
    server_name api.SIZNING-DOMEN.uz;   # <-- o'z domeningiz

    # Yuklanadigan rasm/fayllar uchun limit
    client_max_body_size 10M;

    location / {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;

        # WebSocket (Socket.IO — real-time buyurtma kuzatuvi) uchun SHART
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # Haqiqiy host/IP/protokolni backendga uzatish
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Uzoq so'rovlar uchun (Socket.IO uzilib qolmasin)
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }
}

# Certbot ishlagach avtomatik quyidagilar qo'shiladi:
#   listen 443 ssl;
#   ssl_certificate /etc/letsencrypt/live/api.SIZNING-DOMEN.uz/fullchain.pem;
#   ssl_certificate_key /etc/letsencrypt/live/api.SIZNING-DOMEN.uz/privkey.pem;
#   va 80 → 443 redirect
