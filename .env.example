# ===== LokmaGo Backend sozlamalari =====
# Bu faylni .env deb nusxalang:  cp .env.example .env

PORT=4000

# MongoDB — O'ZINGIZNIKINI QO'YING
# Lokal:  mongodb://localhost:27017/lokmago
# Atlas:  mongodb+srv://user:parol@cluster0.xxxxx.mongodb.net/lokmago
MONGO_URI=mongodb://localhost:27017/lokmago

# JWT maxfiy kaliti (ishlab chiqarishda murakkab qiymat qo'ying)
JWT_SECRET=change-me-in-production

# ===== DASTUR EGASI (ADMIN) LOGIN/PAROL =====
# Admin panelга (lakmago.uz/eka) shu login/parol bilan kiriladi.
# Server ishga tushganda shu akkaunt avtomatik yaratiladi.
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin123

# CORS — client va admin panel manzillari (vergul bilan)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# Telegram bot tokeni (BotFather'dan). Bo'sh bo'lsa demo/mehmon rejim.
TELEGRAM_BOT_TOKEN=

# To'lov (ixtiyoriy)
PAYME_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=

# ===== CLOUDINARY (rasm saqlash) =====
# console.cloudinary.com → Dashboard'dan oling.
# API SECRET'ni HECH KIMGA bermang, faqat shu serverda turadi!
CLOUDINARY_CLOUD_NAME=dnq8oy7l8
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
# Unsigned upload preset nomi (Cloudinary Settings → Upload → Upload presets'da yarating,
# Signing Mode = Unsigned). Frontend shu preset bilan to'g'ridan yuklaydi (secret kerak emas).
CLOUDINARY_UPLOAD_PRESET=lokmago_unsigned

# ===== TELEGRAM WEBAPP =====
# Guruhlarga yuboriladigan "Buyurtma berish" tugmasi shu manzilга o'tkazadi.
# Bot mini-app: https://t.me/SizningBot/app  yoki webapp domeni: https://lokmago.uz
WEBAPP_URL=https://t.me/LokmaGoBot/app

# MUHIM: Webhook o'rnatishда 'my_chat_member' update yoqilishi shart (bot admin
# qilinganини bilish uchun). Quyidagi buyruq bilan o'rnating:
# curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://SIZNING-SERVER/bot/webhook&allowed_updates=[\"message\",\"my_chat_member\"]"

# ===== ASOSIY KANAL + REFERRAL TIZIMI =====
# Majburiy obuna kanали (@username yoki -100... super-guruh id).
# Bo'sh qoldirilса — obuna talab qilinmaydi.
MAIN_CHANNEL=@LokmaGoUz
MAIN_CHANNEL_URL=https://t.me/LokmaGoUz
BOT_USERNAME=LokmaGoBot
# Referal bonuslari (so'mда)
REFERRAL_REWARD=5000       # taklif qiluvchiga
REFERRAL_WELCOME=3000      # yangi qo'shilganга

# MUHIM: Referal «Tekshirish» tugmasi ishlashi uchun webhook'да 'callback_query'
# ham yoqилиши kerak:
# curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://SERVER/bot/webhook&allowed_updates=[\"message\",\"my_chat_member\",\"callback_query\"]"
WEBAPP_NAME=app

# ===== DEPLOY (Vercel + server) =====
# Vercel'даgi webapp/admin domenlarини shu yerга yozing (vergul bilan).
# Vercel (*.vercel.app) va Telegram domenlarи AVTOMATIK ruxsat etiladi,
# lekin o'z domeningiz bo'lsa (masalan https://lokmago.uz) shu yerга qo'shing:
CORS_ORIGINS=https://lokmago.uz,https://admin.lokmago.uz

# MUHIM: Vercel HTTPS ishlatadi. Agar backend HTTP bo'lsa (http://IP:4000),
# brauzer "Mixed Content" deb bloklaydi va data kelmaydi!
# Yechim: backendга HTTPS qo'ying (Nginx + Let's Encrypt / Certbot),
# so'ng Vercel'да VITE_API_URL=https://api.domeningiz.uz/api qilib bering.
