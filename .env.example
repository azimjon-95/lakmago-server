# ===== LokmaGo Backend sozlamalari =====
# Bu faylni .env deb nusxalang va qiymatlarni to'ldiring:
#   cp .env.example .env

# Server porti
PORT=4000

# MongoDB ulanish manzili — O'ZINGIZNIKINI QO'YING
# Lokal Mongo:      mongodb://localhost:27017/lokmago
# MongoDB Atlas:    mongodb+srv://user:parol@cluster0.xxxxx.mongodb.net/lokmago
MONGO_URI=mongodb://localhost:27017/lokmago

# JWT maxfiy kaliti (ishlab chiqarishda murakkab qiymat qo'ying)
JWT_SECRET=change-me-in-production

# Telegram bot tokeni (BotFather'dan olinadi). Bo'sh bo'lsa demo rejim ishlaydi.
TELEGRAM_BOT_TOKEN=

# Frontend (client) manzili — CORS uchun
CLIENT_ORIGIN=http://localhost:5173

# To'lov tizimlari (ixtiyoriy — demo uchun bo'sh qoldirsangiz bo'ladi)
PAYME_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
